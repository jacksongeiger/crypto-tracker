DATABASE_URL=postgresql://localhost/crypto_tracker_dev
GOOGLE_API_KEY=your-gemini-api-key-here
# Optional: register a free key at https://fredaccount.stlouisfed.org/apikey
# Without this, the macro skill exits cleanly with a skip message.
FRED_API_KEY=your-fred-api-key-here

# Daily email digest (scripts/daily_digest.py). Required for the 6:30 AM brief.
# SendGrid API key — create at https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=
# Recipient address for the digest.
DIGEST_EMAIL_TO=jacksongeiger@berkeley.edu
# From address. MUST be a verified SendGrid Single Sender or live on an
# authenticated domain, otherwise SendGrid will reject the send.
# Default placeholder uses merkavian.tech — either (a) verify this exact
# address as a Single Sender at
# https://app.sendgrid.com/settings/sender_auth/senders, or
# (b) authenticate the merkavian.tech domain at
# https://app.sendgrid.com/settings/sender_auth/domain and use any
# from-address under it.
DIGEST_EMAIL_FROM=digest@merkavian.tech
